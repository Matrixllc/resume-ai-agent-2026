# Required: fill this for the default OpenAI deployment path.
OPENAI_API_KEY=your_api_key_here

# Required for public/PaaS deployments. Leave empty only for trusted local demos.
RESUME_APP_PASSWORD=change_me_before_deploy

# Required for split frontend/backend deployment.
# Backend CORS allowlist, comma-separated when multiple frontend origins are needed.
RESUME_API_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Frontend API base URL. Set to your public backend URL on PaaS.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Recommended for PaaS: mount a persistent disk here.
# SQLite, Chroma, uploaded resumes, and scanned resumes should survive restarts.
# RESUME_DATA_ROOT=/persistent/resume-query

# Optional: default OpenAI models for ingestion and QA.
RESUME_V3_OPENAI_MODEL=gpt-4.1-mini
RESUME_V3_OPENAI_EMBED_MODEL=text-embedding-3-small
RESUME_QA_OPENAI_MODEL=gpt-4.1-mini

# Optional: embedding storage contract.
# By default, Chroma collection is derived from provider/model, for example:
# resume_v3_project_chunks_openai_text_embedding_3_small
# Only override when you know the existing collection was built by the same embedding model.
# RESUME_V3_CHROMA_COLLECTION=resume_v3_project_chunks_openai_text_embedding_3_small
# RESUME_TOOLS_CHROMA_COLLECTION=resume_v3_project_chunks_openai_text_embedding_3_small

# Optional: enable stable workflow templates before generic compiler fallback.
RESUME_QA_WORKFLOW_TEMPLATE_COMPILER_ENABLED=true

# Optional: frontend demo upload settings.
# Uploaded resumes are stored persistently under resume/uploads by default.
RESUME_UPLOAD_MAX_MB=20
# RESUME_UPLOAD_DIR=resume/uploads

# Optional: local Ollama mode. Uncomment only when you want local models.
# RESUME_V3_CHAT_PROVIDER=ollama
# RESUME_V3_EMBED_PROVIDER=ollama
# RESUME_V3_OLLAMA_MODEL=llama3:latest
# RESUME_V3_EMBED_MODEL=bge-m3
# RESUME_QA_LLM_PROVIDER=ollama
# RESUME_QA_OLLAMA_MODEL=llama3:latest
# RESUME_QA_OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_HOST=http://localhost:11434
